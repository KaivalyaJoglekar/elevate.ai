{
  "name": "elevate-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "predev": "npm run clean",
    "dev": "next dev",
    "predev:frontend": "npm run clean",
    "dev:frontend": "next dev",
    "dev:backend": "cd server && python3 -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "prebuild": "npm run clean",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.2.12",
    "lucide-react": "^0.460.0",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.15",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  }
}
