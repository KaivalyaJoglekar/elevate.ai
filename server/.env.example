# ── REQUIRED ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key         # Required — get from https://aistudio.google.com/
RAPIDAPI_KEY=your_rapidapi_key             # Required — for JSearch job feed

# ── GEMINI MODEL ─────────────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-1.5-flash,gemini-1.5-flash-8b
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_SECONDS=1.5

# ── UPSTASH REDIS (strongly recommended for production / Render) ──────────────────
# Without this the backend uses in-memory state — task results are lost on restart!
# Get a free DB at https://upstash.com/
UPSTASH_REDIS_URL=rediss://:password@host:port?ssl_cert_reqs=required

# Alternatively set these three instead of UPSTASH_REDIS_URL:
# UPSTASH_REDIS_HOST=
# UPSTASH_REDIS_PORT=
# UPSTASH_REDIS_PASSWORD=

# ── OPTIONAL ──────────────────────────────────────────────────────────────────────
PUBLIC_BACKEND_URL=https://your-render-app.onrender.com
SENTRY_DSN=

RESULT_TTL_SECONDS=604800
CACHE_TTL_SECONDS=604800
UPLOAD_BLOB_TTL_SECONDS=3600
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_DAY=5
MAX_UPLOAD_SIZE_BYTES=5242880
SENTENCE_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
GENERATED_RESUME_DIR=/tmp/elevate-generated
JSEARCH_COUNTRY=in
