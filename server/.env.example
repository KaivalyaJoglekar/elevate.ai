GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BACKOFF_SECONDS=1.5
RAPIDAPI_KEY=your_rapidapi_key
JSEARCH_COUNTRY=in

# Optional. If omitted, the backend runs with an in-memory task/cache store.
# Prefer this single URL for Upstash Redis when you want Celery + Redis enabled.
UPSTASH_REDIS_URL=rediss://:password@host:port?ssl_cert_reqs=required

# Or set these three instead of UPSTASH_REDIS_URL.
UPSTASH_REDIS_HOST=
UPSTASH_REDIS_PORT=
UPSTASH_REDIS_PASSWORD=

PUBLIC_BACKEND_URL=http://localhost:8000
SENTRY_DSN=

RESULT_TTL_SECONDS=604800
CACHE_TTL_SECONDS=604800
UPLOAD_BLOB_TTL_SECONDS=3600
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_DAY=5
MAX_UPLOAD_SIZE_BYTES=5242880
SENTENCE_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
GENERATED_RESUME_DIR=/tmp/elevate-generated
